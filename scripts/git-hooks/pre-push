#!/bin/bash

# Colors
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
NC="\033[0m" # No Color

echo -e "${YELLOW}Running tests before push...${NC}"

# Run pytest with colors forced
pytest --color=yes backend/tests
RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo -e "${RED}Tests failed! Push aborted.${NC}"
    exit 1
fi

echo -e "${GREEN}All tests passed. Proceeding with push.${NC}"
exit 0
